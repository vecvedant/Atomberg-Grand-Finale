# Copy to .env and adjust as needed. Sensible defaults are baked in, so this is optional for local dev.
PORT=3000
HOST=0.0.0.0

# Secret used to sign JWTs (agent/admin sessions + customer invite tokens).
# CHANGE THIS in any non-local deployment.
JWT_SECRET=dev-secret-change-me

# How long an agent/admin login session stays valid.
SESSION_TOKEN_TTL=12h
# How long a customer invite link stays valid.
INVITE_TOKEN_TTL=24h

# Reconnect grace window in milliseconds (how long a dropped participant's slot is held).
RECONNECT_GRACE_MS=15000

# Max upload size for in-call file sharing, in bytes (default 25 MB).
MAX_UPLOAD_BYTES=26214400

# Public base URL used when generating invite links shown to the agent.
PUBLIC_BASE_URL=http://localhost:3000
