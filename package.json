{
  "name": "atomberg-video-support",
  "version": "1.0.0",
  "description": "Self-owned real-time video support platform (SFU, no third-party video APIs)",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --import tsx --watch src/server.ts",
    "start": "node --import tsx src/server.ts",
    "seed": "node --import tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "check:platform": "node scripts/phase1-check.mjs",
    "check:media": "node scripts/browser-sfu-check.mjs",
    "check:recording": "node scripts/recording-check.mjs",
    "check:files": "node scripts/file-check.mjs",
    "check:reconnect": "node scripts/reconnect-check.mjs",
    "check:hierarchy": "node scripts/hierarchy-check.mjs",
    "check:intake": "node scripts/intake-check.mjs",
    "check:intake-accept": "node scripts/intake-accept-check.mjs",
    "check:track": "node scripts/track-check.mjs",
    "check:schedule": "node scripts/schedule-check.mjs",
    "check:queue": "node scripts/queue-check.mjs",
    "check:reschedule": "node scripts/reschedule-check.mjs",
    "check:backguard": "node scripts/backguard-check.mjs"
  },
  "keywords": [
    "webrtc",
    "sfu",
    "video-support",
    "werift"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "werift": "^0.23.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.21",
    "puppeteer": "^23.11.1",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
